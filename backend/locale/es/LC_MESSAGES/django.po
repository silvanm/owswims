#: app/admin.py:30
msgid "Open-Water-Swims Admin"
msgstr "Administración de Open-Water-Swims"

#: app/models.py:61
msgid "Location"
msgstr "Ubicación"

#: app/models.py:62
msgid "Locations"
msgstr "Ubicaciones"

#: app/models.py:132
msgid "Organizer"
msgstr "Organizador"

#: app/models.py:133
msgid "Organizers"
msgstr "Organizadores"

#: app/models.py:363
msgid "Event"
msgstr "Evento"

#: app/models.py:364
msgid "Events"
msgstr "Eventos"

#: app/models.py:431
