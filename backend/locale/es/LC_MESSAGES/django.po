msgstr "Carrera"

#: app/models.py:432
msgid "Races"
msgstr "Carreras"

#: app/organizer_admin.py:23
msgid ""
"Optional: Full address for precise map placement. If left empty, we'll use "
"the city and country to determine coordinates."
msgstr ""
"Opcional: Dirección completa para una ubicación precisa en el mapa. Si se "
"deja vacío, usaremos la ciudad y el país para determinar las coordenadas."

#: app/organizer_admin.py:33
msgid "The city or town where the event takes place"
msgstr "La ciudad o pueblo donde se realiza el evento"

#: app/organizer_admin.py:34
msgid "Name of the body of water (e.g., 'Lake Zurich', 'Rhine River')"
msgstr "Nombre del cuerpo de agua (ej., 'Lago de Zúrich', 'Río Rin')"

#: app/organizer_admin.py:35
msgid "Type of water body - helps swimmers know what to expect"
msgstr "Tipo de cuerpo de agua - ayuda a los nadadores a saber qué esperar"

#: app/organizer_admin.py:36
msgid "Country where the location is"
msgstr "País donde se encuentra la ubicación"

#: app/organizer_admin.py:37
msgid "A scenic photo of the location (shown on the event page)"
msgstr "Una foto escénica de la ubicación (se muestra en la página del evento)"

#: app/organizer_admin.py:44
msgid "Open Water Swims - Organizer Portal (Beta)"
msgstr "Open Water Swims - Portal de Organizadores (Beta)"

#: app/organizer_admin.py:45
msgid "Organizer Portal (Beta)"
msgstr "Portal de Organizadores (Beta)"

#: app/organizer_admin.py:46
msgid "Manage Your Events"
msgstr "Gestiona tus eventos"

#: app/organizer_admin.py:74
msgid "Your organization's name as shown to swimmers"
msgstr "Nombre de tu organización como se muestra a los nadadores"

#: app/organizer_admin.py:76
msgid "Your main website URL"
msgstr "URL principal de tu sitio web"

#: app/organizer_admin.py:78
msgid "Your organization's logo (displayed on event pages)"
msgstr "Logo de tu organización (se muestra en las páginas de eventos)"

#: app/organizer_admin.py:80
msgid "Email for swimmer inquiries (not shown publicly)"
msgstr "Correo para consultas de nadadores (no se muestra públicamente)"

#: app/organizer_admin.py:127
msgid "Race / Distance"
msgstr "Carrera / Distancia"

#: app/organizer_admin.py:128
msgid "Races / Distances (add one row per distance offered)"
msgstr "Carreras / Distancias (agrega una fila por cada distancia ofrecida)"

#: app/organizer_admin.py:164
msgid "Dates & Location"
msgstr "Fechas y ubicación"

#: app/organizer_admin.py:166
msgid "Set the event dates and choose or create a location."
msgstr "Establece las fechas del evento y elige o crea una ubicación."

#: app/organizer_admin.py:168
msgid "Requirements"
msgstr "Requisitos"

#: app/organizer_admin.py:170
msgid "Let swimmers know what they need to participate."
msgstr "Informa a los nadadores qué necesitan para participar."

#: app/organizer_admin.py:172
msgid "Status"
msgstr "Estado"

#: app/organizer_admin.py:174
msgid "Update if registration is closed or the event is cancelled."
msgstr ""
"Actualiza si la inscripción está cerrada o el evento ha sido cancelado."

#: app/organizer_admin.py:176 app/organizer_admin.py:230
msgid "Statistics (read-only)"
msgstr "Estadísticas (solo lectura)"

#: app/organizer_admin.py:178
msgid "These fields are automatically updated by our system."
msgstr "Estos campos se actualizan automáticamente por nuestro sistema."

#: app/organizer_admin.py:189
msgid "The official name of your event"
msgstr "Nombre oficial de tu evento"

#: app/organizer_admin.py:190
msgid "Link to your event's registration or info page"
msgstr "Enlace a la página de inscripción o información de tu evento"

#: app/organizer_admin.py:191
msgid "A brief description shown to swimmers (supports basic formatting)"
msgstr "Breve descripción mostrada a los nadadores (soporta formato básico)"

#: app/organizer_admin.py:192
msgid "Upload your event flyer or poster (optional)"
msgstr "Sube el folleto o cartel de tu evento (opcional)"

#: app/organizer_admin.py:193
msgid "First day of the event"
msgstr "Primer día del evento"

#: app/organizer_admin.py:194
msgid "Last day of the event (same as start date for single-day events)"
msgstr ""
"Último día del evento (igual que la fecha de inicio para eventos de un solo "
"día)"

#: app/organizer_admin.py:195
msgid "Select an existing location or create a new one"
msgstr "Selecciona una ubicación existente o crea una nueva"

#: app/organizer_admin.py:196
msgid "Expected water temperature in Celsius (helps swimmers prepare)"
msgstr ""
"Temperatura esperada del agua en Celsius (ayuda a los nadadores a prepararse)"

#: app/organizer_admin.py:197
msgid "Is a medical certificate required to participate?"
msgstr "¿Se requiere certificado médico para participar?"

#: app/organizer_admin.py:198
msgid "Is a federation license required?"
msgstr "¿Se requiere licencia federativa?"

#: app/organizer_admin.py:199
msgid "Is this a timed race with results/rankings? (Uncheck for casual swims)"
msgstr ""
"¿Es una carrera cronometrada con resultados/rankings? (Desmarcar para nados "
"recreativos)"

#: app/organizer_admin.py:200
msgid "Check if registration is full/closed"
msgstr "Marca si la inscripción está llena/cerrada"

#: app/organizer_admin.py:201
msgid "Check if the event has been cancelled"
msgstr "Marca si el evento ha sido cancelado"

#: app/organizer_admin.py:202
msgid "Number of swimmers viewing this event (from analytics)"
msgstr "Número de nadadores que ven este evento (según analíticas)"

#: app/organizer_admin.py:203
msgid "When we last verified the event details"
msgstr "Última vez que verificamos los detalles del evento"

#: app/templates/claim/already_claimed.html:7
#: app/templates/claim/already_claimed.html:95
msgid "Already Claimed"
msgstr "Ya reclamado"

#: app/templates/claim/already_claimed.html:88
#: app/templates/claim/invalid_token.html:91
#: app/templates/claim/set_password.html:132
msgid "Open Water Swims - Organizer Portal"
msgstr "Open Water Swims - Portal de Organizadores (Beta)"

#: app/templates/claim/already_claimed.html:97
#, python-format
msgid ""
"The organizer profile for <span class=\"organizer-name\">%(name)s</span> has "
"already been claimed and linked to an account."
msgstr ""
"El perfil de organizador de <span class=\"organizer-name\">%(name)s</span> "
"ya ha sido reclamado y vinculado a una cuenta."

#: app/templates/claim/already_claimed.html:100
msgid "If this is your organization, you can log in to the organizer portal."
msgstr ""
"Si esta es su organización, puede iniciar sesión en el portal de "
"organizadores."

#: app/templates/claim/already_claimed.html:103
#: app/templates/claim/invalid_token.html:102
msgid "Go to Organizer Portal"
msgstr "Portal de Organizadores (Beta)"

#: app/templates/claim/invalid_token.html:7
msgid "Invalid Link"
msgstr "Enlace no válido"

#: app/templates/claim/invalid_token.html:98
msgid "Link Already Used"
msgstr "Enlace ya utilizado"

#: app/templates/claim/invalid_token.html:100
msgid ""
"This claim link has already been used. If you've already set up your "
"account, you can log in to the organizer portal."
msgstr ""
"Este enlace de reclamación ya ha sido utilizado. Si ya configuró su cuenta, "
"puede iniciar sesión en el portal de organizadores."

#: app/templates/claim/invalid_token.html:105
msgid "Link Expired"
msgstr "Enlace expirado"

#: app/templates/claim/invalid_token.html:107
msgid "This claim link has expired. Claim links are valid for one year."
msgstr ""
"Este enlace de reclamación ha expirado. Los enlaces de reclamación son "
"válidos por un año."

#: app/templates/claim/invalid_token.html:108
msgid "Please contact us to request a new link."
msgstr "Por favor, contáctenos para solicitar un nuevo enlace."

#: app/templates/claim/invalid_token.html:110
msgid "Contact Support"
msgstr "Contactar soporte"

#: app/templates/claim/set_password.html:7
msgid "Claim Your Organizer Profile"
msgstr "Reclame su perfil de organizador"

#: app/templates/claim/set_password.html:137
msgid "Claim Your Profile"
msgstr "Reclame su perfil"

#: app/templates/claim/set_password.html:140
#, python-format
msgid "Welcome, <span class=\"organizer-name\">%(name)s</span>!"
msgstr "¡Bienvenido, <span class=\"organizer-name\">%(name)s</span>!"

#: app/templates/claim/set_password.html:141
msgid ""
"Set a password to access your organizer portal where you can manage your "
"events."
msgstr ""
"Establezca una contraseña para acceder a su portal de organizador donde "
"podrá gestionar sus eventos."

#: app/templates/claim/set_password.html:146
msgid "Please correct the errors below:"
msgstr "Por favor, corrija los errores a continuación:"

#: app/templates/claim/set_password.html:159
msgid "Password:"
msgstr "Contraseña:"

#: app/templates/claim/set_password.html:161
msgid "At least 8 characters"
msgstr "Al menos 8 caracteres"

#: app/templates/claim/set_password.html:165
msgid "Confirm Password:"
msgstr "Confirmar contraseña:"

#: app/templates/claim/set_password.html:170
msgid "Set Password & Access Portal"
msgstr "Establecer contraseña y acceder al portal"

#: app/templates/organizer_admin/login.html:9
msgid "Don't have an account yet? Contact us at"
msgstr "¿Aún no tienes cuenta? Contáctanos en"

#: app/templates/organizer_admin/login.html:13
msgid "to request access to the Organizer Portal."
msgstr "para solicitar acceso al Portal de Organizadores."

#: app/views.py:111
msgid "Password is required."
msgstr "La contraseña es obligatoria."

#: app/views.py:113
msgid "Password must be at least 8 characters."
msgstr "La contraseña debe tener al menos 8 caracteres."

#: app/views.py:115
msgid "Passwords do not match."
msgstr "Las contraseñas no coinciden."

#: app/views.py:127
msgid "Organizer does not have a contact email set. Please contact support."
msgstr ""
"El organizador no tiene un correo de contacto configurado. Por favor, "
"contacte al soporte."

