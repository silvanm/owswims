msgstr "Lieu"

#: app/models.py:62
msgid "Locations"
msgstr "Lieux"

#: app/models.py:132
msgid "Organizer"
msgstr "Organisateur"

#: app/models.py:133
msgid "Organizers"
msgstr "Organisateurs"

#: app/models.py:363
