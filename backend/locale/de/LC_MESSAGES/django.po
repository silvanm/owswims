#: app/organizer_admin.py:23
msgid ""
"Optional: Full address for precise map placement. If left empty, we'll use "
"the city and country to determine coordinates."
msgstr "Optional: Vollständige Adresse für genaue Kartenplatzierung. Wenn leer, verwenden wir Stadt und Land zur Bestimmung der Koordinaten."

#: app/organizer_admin.py:33
msgid "The city or town where the event takes place"
msgstr "Die Stadt oder Gemeinde, in der die Veranstaltung stattfindet"

#: app/organizer_admin.py:34
msgid "Name of the body of water (e.g., 'Lake Zurich', 'Rhine River')"
msgstr "Name des Gewässers (z. B. „Zürichsee“, „Rhein“)"

#: app/organizer_admin.py:35
msgid "Type of water body - helps swimmers know what to expect"
msgstr "Art des Gewässers – hilft Schwimmern bei der Vorbereitung"

#: app/organizer_admin.py:36
msgid "Country where the location is"
msgstr "Land, in dem sich der Standort befindet"

#: app/organizer_admin.py:37
msgid "A scenic photo of the location (shown on the event page)"
msgstr "Ein stimmungsvolles Foto des Standorts (wird auf der Veranstaltungsseite angezeigt)"

#: app/organizer_admin.py:44
msgid "Open Water Swims - Organizer Portal (Beta)"
msgstr "Open Water Swims – Veranstalter-Portal (Beta)"

#: app/organizer_admin.py:45
msgid "Organizer Portal (Beta)"
msgstr "Veranstalter-Portal (Beta)"

#: app/organizer_admin.py:46
msgid "Manage Your Events"
msgstr "Ihre Veranstaltungen verwalten"

#: app/organizer_admin.py:73
msgid "Your organization's name as shown to swimmers"
msgstr "Name Ihrer Organisation, wie er Schwimmern angezeigt wird"

#: app/organizer_admin.py:75
msgid "Your main website URL"
msgstr "URL Ihrer Hauptwebsite"

#: app/organizer_admin.py:77
msgid "Your organization's logo (displayed on event pages)"
msgstr "Logo Ihrer Organisation (wird auf Veranstaltungsseiten angezeigt)"

#: app/organizer_admin.py:79
msgid "Email for swimmer inquiries (not shown publicly)"
msgstr "E-Mail für Schwimmeranfragen (nicht öffentlich sichtbar)"

#: app/organizer_admin.py:126
msgid "Race / Distance"
msgstr "Rennen / Distanz"

#: app/organizer_admin.py:127
msgid "Races / Distances (add one row per distance offered)"
msgstr "Rennen / Distanzen (eine Zeile pro angebotener Distanz hinzufügen)"

#: app/organizer_admin.py:163
msgid "Dates & Location"
msgstr "Termine & Standort"

#: app/organizer_admin.py:165
msgid "Set the event dates and choose or create a location."
msgstr "Legen Sie die Veranstaltungstermine fest und wählen oder erstellen Sie einen Standort."

#: app/organizer_admin.py:167
msgid "Requirements"
msgstr "Anforderungen"

#: app/organizer_admin.py:169
msgid "Let swimmers know what they need to participate."
msgstr "Informieren Sie Schwimmer über die Teilnahmevoraussetzungen."

#: app/organizer_admin.py:171
msgid "Status"
msgstr "Status"

#: app/organizer_admin.py:173
msgid "Update if registration is closed or the event is cancelled."
msgstr "Aktualisieren Sie, wenn die Anmeldung geschlossen oder die Veranstaltung abgesagt ist."

#: app/organizer_admin.py:175
msgid "Statistics (read-only)"
msgstr "Statistiken (nur lesbar)"

#: app/organizer_admin.py:177
msgid "These fields are automatically updated by our system."
msgstr "Diese Felder werden automatisch von unserem System aktualisiert."

#: app/organizer_admin.py:188
msgid "The official name of your event"
msgstr "Offizieller Name Ihrer Veranstaltung"

#: app/organizer_admin.py:189
msgid "Link to your event's registration or info page"
msgstr "Link zur Anmeldeseite oder Infoseite Ihrer Veranstaltung"

#: app/organizer_admin.py:190
msgid "A brief description shown to swimmers (supports basic formatting)"
msgstr "Kurzbeschreibung für Schwimmer (unterstützt einfache Formatierung)"

#: app/organizer_admin.py:191
msgid "Upload your event flyer or poster (optional)"
msgstr "Laden Sie Ihren Veranstaltungsflyer oder Ihr Plakat hoch (optional)"

#: app/organizer_admin.py:192
msgid "First day of the event"
msgstr "Erster Veranstaltungstag"

#: app/organizer_admin.py:193
msgid "Last day of the event (same as start date for single-day events)"
msgstr "Letzter Veranstaltungstag (bei Eintagesveranstaltungen gleich wie Startdatum)"

#: app/organizer_admin.py:194
msgid "Select an existing location or create a new one"
msgstr "Wählen Sie einen bestehenden Standort oder erstellen Sie einen neuen"

#: app/organizer_admin.py:195
msgid "Expected water temperature in Celsius (helps swimmers prepare)"
msgstr "Erwartete Wassertemperatur in Celsius (hilft Schwimmern bei der Vorbereitung)"

#: app/organizer_admin.py:196
msgid "Is a medical certificate required to participate?"
msgstr "Wird ein ärztliches Attest zur Teilnahme benötigt?"

#: app/organizer_admin.py:197
msgid "Is a federation license required?"
msgstr "Wird eine Verbandslizenz benötigt?"

#: app/organizer_admin.py:198
msgid "Is this a timed race with results/rankings? (Uncheck for casual swims)"
msgstr "Ist dies ein Zeitrennen mit Ergebnissen/Ranglisten? (Deaktivieren für lockere Schwimmen)"

#: app/organizer_admin.py:199
msgid "Check if registration is full/closed"
msgstr "Ankreuzen, wenn die Anmeldung voll/geschlossen ist"

#: app/organizer_admin.py:200
msgid "Check if the event has been cancelled"
msgstr "Ankreuzen, wenn die Veranstaltung abgesagt wurde"

#: app/organizer_admin.py:201
msgid "Number of swimmers viewing this event (from analytics)"
msgstr "Anzahl der Schwimmer, die diese Veranstaltung ansehen (laut Analyse)"

#: app/organizer_admin.py:202
msgid "When we last verified the event details"
msgstr "Wann wir die Veranstaltungsdetails zuletzt überprüft haben"

#: app/templates/claim/already_claimed.html:7
#: app/templates/claim/already_claimed.html:95
msgid "Already Claimed"
msgstr "Bereits beansprucht"

